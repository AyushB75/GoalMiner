# ── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/
*.egg
pip-wheel-metadata/

# ── Virtual environments ───────────────────────────────────────────────────
venv/
.venv/
env/
.env/
ENV/

