.env
.env.local
.env.*.local

# ── Model artifacts (large binary files — regenerate with train_regression.py)
backend/models/artifacts/*.joblib
backend/models/artifacts/*.parquet
# Keep metrics JSON (small, useful to track)
!backend/models/artifacts/model_metrics.json

# ── Datasets (large CSVs — store separately or via DVC/LFS)
dataset/

# ── Jupyter checkpoints ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints/

# ── Frontend build / deps ─────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# ── OS files ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs / temp ───────────────────────────────────────────────────────────
*.log
tmp/
temp/
